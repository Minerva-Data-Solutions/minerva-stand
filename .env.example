# Copy to .env and fill in. Docker Compose loads this file into containers (env_file).
# cp .env.example .env

# --- LLM provider (set the key that matches NANOBOT_PROVIDER / model) ---
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=

NANOBOT_MODEL=openai/gpt-4o-mini
NANOBOT_PROVIDER=openrouter

# --- Minerva Workbench (nanobot serve / stand-api) ---
MINERVA_UI_USER=admin
MINERVA_UI_PASSWORD=changeme

# Browser origins for the Workbench API (comma-separated). If unset, sensible dev defaults apply.
# MINERVA_UI_CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# Optional: stable session signing (defaults to a derived value if unset)
# MINERVA_UI_SECRET=

# UI build: explicit API origin (optional). If unset, the app uses same hostname as the UI + VITE_API_PORT (8900).
# VITE_API_BASE_URL=
# VITE_API_PORT=8900

# Dev only: Vite proxy target for `npm run dev`
# VITE_PROXY_TARGET=http://127.0.0.1:8900

# Docker build: legacy override when not using same-hostname + VITE_API_PORT
# VITE_API_BASE_URL=http://127.0.0.1:8900